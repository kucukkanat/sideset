{
  "name": "keychain",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @keychain/app dev",
    "build": "bun run --filter @keychain/app build",
    "preview": "bun run --filter @keychain/app preview",
    "typecheck": "tsc --noEmit -p packages/core && tsc --noEmit -p packages/app && tsc --noEmit -p packages/app/tsconfig.worker.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "bun test packages/core",
    "test:integration": "bun test packages/app",
    "test:coverage": "bun test packages --coverage",
    "check": "bun run typecheck && bun run lint && bun run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@changesets/cli": "^2.29.0",
    "@types/bun": "^1.3.0",
    "typescript": "^5.9.0"
  }
}
